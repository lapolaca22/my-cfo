# ── Supabase (Python server-side — use service_role key, never expose to browser) ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── ERP ──────────────────────────────────────────────────────────────────
ERP_BASE_URL=https://your-erp.example.com/api/v1
ERP_API_KEY=your_erp_api_key_here
ERP_COMPANY_ID=COMPANY_001

# ── Bank / Open Banking ───────────────────────────────────────────────────
BANK_BASE_URL=https://your-bank-api.example.com
BANK_CLIENT_ID=your_bank_client_id
BANK_CLIENT_SECRET=your_bank_client_secret
BANK_ACCOUNT_ID=DE89370400440532013000

# ── CRM ───────────────────────────────────────────────────────────────────
CRM_BASE_URL=https://your-crm.example.com/api
CRM_API_KEY=your_crm_api_key_here

# ── Email ─────────────────────────────────────────────────────────────────
EMAIL_HOST=mail.example.com
EMAIL_USERNAME=finance-bot@example.com
EMAIL_PASSWORD=your_email_password_here
EMAIL_INVOICE_INBOX=Invoices

# ── File Storage ──────────────────────────────────────────────────────────
STORAGE_BASE_PATH=/data/finance

# ── Agent configuration ───────────────────────────────────────────────────
AP_APPROVER_EMAILS=cfo@example.com,coo@example.com
AR_REVIEW_EMAIL=finance@example.com
REPORT_RECIPIENTS=cfo@example.com
BASE_CURRENCY=EUR
